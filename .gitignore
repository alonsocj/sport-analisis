# Datos: por defecto NO versionar (bronze crudo, dumps, etc.)
data/*
!data/gold
!data/silver
!data/knockouts
!data/rosters
!data/bronze
data/bronze/*
!data/bronze/public_results
data/bronze/public_results/*
!data/bronze/public_results/results.csv

# Excepción: artefactos derivados (datos públicos) que la app Streamlit
# necesita para desplegar. El secreto (API key) sigue solo en .env.
data/gold/*
!data/gold/team_features.csv
!data/gold/elo_history.csv
!data/gold/external_elo.csv
!data/gold/player_factor.csv
!data/gold/dixon_coles_params.json
!data/gold/half_signal.csv
data/silver/*
!data/silver/matches.csv
data/knockouts/*
!data/knockouts/r32_fixtures.csv
!data/knockouts/r16_fixtures.csv
!data/knockouts/r8_fixtures.csv
!data/knockouts/r4_fixtures.csv
data/rosters/*
!data/rosters/r32_rosters.csv
!data/rosters/r32_unavailable.csv
# F31: alineaciones (XI + destacado) que la sub-pestaña Alineación necesita en el deploy
!data/bronze/lineups
data/bronze/lineups/*.meta.json

# Secretos
.env
.env.*

# Entorno virtual
.venv/
venv/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
*.egg-info/
.cache/
